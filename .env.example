MARGIN_DATABASE_URL=postgresql+psycopg://margin:margin@localhost:5432/margin
MARGIN_TEST_DATABASE_URL=postgresql+psycopg://margin:margin@localhost:5432/margin_test

# Provider URL/token/model settings are managed in the app Settings page and
# encrypted into provider_config_versions/provider_secret_versions.
MARGIN_WEB_ORIGIN=http://localhost:3000

MARGIN_LOG_LEVEL=INFO
MARGIN_LOG_FORMAT=console
MARGIN_METRICS_ENABLED=true
MARGIN_MONITORING_INTERVAL_SECONDS=10
MARGIN_ENVIRONMENT=development
GRAFANA_ADMIN_PASSWORD=margin
GRAFANA_PORT=3002
